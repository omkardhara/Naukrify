# Copy this file to .env.local and fill in your values.

# Supabase — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Settings > API > service_role

# Razorpay — Dashboard > Settings > API Keys
# Key ID is public (NEXT_PUBLIC_ prefix), secret is server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret-here

# Stripe — optional, for international (non-India) payments
# Dashboard > Developers > API Keys
# Leave blank to hide the Stripe payment option
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # optional: pre-created price object in Stripe dashboard

# Site URL — used in Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=https://naukrify.com
